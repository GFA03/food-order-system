{
  "id": null,
  "uid": "omnieats-http-overview",
  "title": "OmniEats — HTTP Overview",
  "tags": ["omnieats", "http"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate per Service (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (application)(rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latency p95 per Service (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, application)(rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p95 {{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency p50 per Service (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, application)(rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p50 {{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Latency p99 per Service (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, application)(rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p99 {{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP Error Rate (4xx/5xx) per Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (application)(rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[5m]))",
          "legendFormat": "errors {{application}}",
          "refId": "A"
        }
      ]
    }
  ]
}
