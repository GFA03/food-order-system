{
  "id": null,
  "uid": "omnieats-jvm-metrics",
  "title": "OmniEats — JVM Metrics",
  "tags": ["omnieats", "jvm"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Heap Used (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{application}} {{id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Heap Committed (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "jvm_memory_committed_bytes{area=\"heap\"}",
          "legendFormat": "{{application}} {{id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "GC Pause Time (s/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum[5m])",
          "legendFormat": "{{application}} {{action}} {{cause}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Live Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "process_cpu_usage",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    }
  ]
}
